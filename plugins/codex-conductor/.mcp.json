{
  "mcpServers": {
    "grep_app": {
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp"
    },
    "codegraph": {
      "command": "node",
      "args": [
        "./scripts/codegraph-mcp.mjs"
      ],
      "cwd": ".",
      "required": false
    },
    "git_bash": {
      "command": "node",
      "args": [
        "./runtime/git-bash-mcp/dist/cli.js",
        "mcp"
      ],
      "cwd": ".",
      "required": false
    },
    "lsp": {
      "command": "node",
      "args": [
        "./runtime/lsp-daemon/dist/cli.js",
        "mcp"
      ],
      "cwd": "."
    }
  }
}
