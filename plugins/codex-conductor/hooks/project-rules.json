{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/rules-hook.mjs\" hook session-start",
            "timeout": 10,
            "statusMessage": "Loading project rules"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/rules-hook.mjs\" hook user-prompt-submit",
            "timeout": 10,
            "statusMessage": "Loading project rules"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/rules-hook.mjs\" hook post-tool-use",
            "timeout": 10,
            "statusMessage": "Matching project rules"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/rules-hook.mjs\" hook post-compact",
            "timeout": 10,
            "statusMessage": "Resetting project-rule cache"
          }
        ]
      }
    ]
  }
}
